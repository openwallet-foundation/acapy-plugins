# integration/example.env — copy to .env and update as needed
#
#   cp example.env .env
#
# The .env file is git-ignored. All values below are the defaults used by
# docker-compose.yml when the variable is unset, so you only need to change
# the lines that differ from your local setup.

# ── Host port bindings ──────────────────────────────────────────────────────
# Change these if the defaults clash with other services on your machine.

ACAPY_ISSUER_INBOUND_PORT=18020
ACAPY_ISSUER_ADMIN_PORT=18021
ACAPY_ISSUER_OID4VCI_PORT=18022

ACAPY_VERIFIER_INBOUND_PORT=18030
ACAPY_VERIFIER_ADMIN_PORT=18031
ACAPY_VERIFIER_OID4VP_PORT=18032
ACAPY_VERIFIER_OID4VCI_PORT=18033

CREDO_PORT=13021
SPHEREON_PORT=13010

# ── Optional overrides ──────────────────────────────────────────────────────
# WALLET_STORAGE_TYPE=sqlite        # sqlite (default) or postgres
# LOG_LEVEL=DEBUG
# OID4VC_MDOC_TRUST_STORE_TYPE=wallet   # wallet (default) or file

# ── zrok public tunnel endpoints ───────────────────────────────────────────
# Names must be lowercase alphanumeric only (no hyphens/underscores), 4–32 chars.
#
# Reserve tunnel names once (permanent):
#   zrok reserve public --unique-name "myconformanceserver" https://localhost:8443
#   zrok reserve public --unique-name "myoid4vciissuer"     http://localhost:18022
#   zrok reserve public --unique-name "myoid4vpverifier"    http://localhost:18032
#
# Activate tunnels each session (in separate terminals):
#   zrok share reserved --insecure myconformanceserver
#   zrok share reserved myoid4vciissuer
#   zrok share reserved myoid4vpverifier

# Public URL the conformance server advertises in redirect_uris.
# Required when testing with mobile wallets (can't reach localhost).
# CONFORMANCE_SERVER_BASE_URL=https://myconformanceserver.share.zrok.io

# Public URLs the ACA-Py agent services advertise in /.well-known metadata.
# Required so the conformance server (inside Docker) can call back to them.
# ISSUER_OID4VCI_ENDPOINT=https://myoid4vciissuer.share.zrok.io
# VERIFIER_OID4VP_ENDPOINT=https://myoid4vpverifier.share.zrok.io
