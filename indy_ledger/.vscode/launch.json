  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run/Debug Plugin",
      "type": "python",
      "request": "launch",
      "module": "acapy_agent",
      "justMyCode": false,
      "args": [
        "start",
        "--arg-file=${workspaceRoot}/docker/default.yml"
      ]
    },
    {
      "name": "Run/Debug Multitenant Admin Plugin",
      "type": "python",
      "request": "launch",
      "module": "acapy_agent",
      "justMyCode": false,
      "args": [
        "start",
        "--arg-file=${workspaceRoot}/docker/multitenant-admin.yml"
      ]
    },
    {
      "name": "ruff - indy_ledger",
      "type": "python",
      "request": "launch",
      "module": "ruff",
      "console": "integratedTerminal",
      "sudo": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}/indy_ledger",
      "args": [
        "check",
        "."
      ]
    },
    {
      "name": "ruff fix - indy_ledger",
      "type": "python",
      "request": "launch",
      "module": "ruff",
      "console": "integratedTerminal",
      "sudo": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}/indy_ledger",
      "args": [
        "check",
        ".",
        "--fix"
      ]
    }
  ]
}